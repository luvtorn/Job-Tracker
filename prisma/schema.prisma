// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SEEKER
  RECRUITER
  ADMIN
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  email        String @unique
  passwordHash String @map("password_hash")

  firstName String? @map("first_name")
  lastName  String? @map("last_name")

  avatarUrl      String? @map("avatar_url")
  avatarPublicId String? @map("avatar_public_id")

  emailVerified Boolean @default(false) @map("email_verified")

  role UserRole @default(SEEKER)

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  refreshTokens RefreshToken[]
  vacancies     Vacancy[]
  applications  Application[]
  wishlist      Wishlist[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

enum VacancyStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  REJECTED
  OFFER
  ACCEPTED
  WITHDRAWN
}

model Vacancy {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  title        String
  description  String
  requirements String?

  position  String?
  company   String?
  location  String?
  salaryMin Int?    @map("salary_min")
  salaryMax Int?    @map("salary_max")
  currency  String  @default("USD")

  status VacancyStatus @default(DRAFT)

  recruiterId String @db.Uuid
  recruiter   User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  applications Application[]
  wishlist     Wishlist[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")
  closedAt    DateTime? @map("closed_at")
  expiresAt   DateTime? @map("expires_at")
  archivedAt  DateTime? @map("archived_at")

  @@index([recruiterId])
  @@index([status])
  @@index([archivedAt])
  @@index([expiresAt])
  @@index([createdAt(sort: Desc)])
  @@map("vacancies")
}

model Application {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  status ApplicationStatus @default(APPLIED)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vacancyId String  @db.Uuid
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  interviewDate DateTime? @map("interview_date")
  interviewTime String?   @map("interview_time")
  interviewNotes String?  @map("interview_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, vacancyId])
  @@index([userId])
  @@index([vacancyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("applications")
}

model Wishlist {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vacancyId String  @db.Uuid
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, vacancyId])
  @@index([userId])
  @@index([vacancyId])
  @@map("wishlist")
}

model Notification {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  type String
  title String
  message String
  isRead Boolean @default(false) @map("is_read")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicationId String? @db.Uuid
  vacancyId     String? @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}
