// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SEEKER
  RECRUITER
  ADMIN
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  email        String @unique
  passwordHash String @map("password_hash")

  firstName String? @map("first_name")
  lastName  String? @map("last_name")

  avatarUrl      String? @map("avatar_url")
  avatarPublicId String? @map("avatar_public_id")

  emailVerified Boolean @default(false) @map("email_verified")

  role UserRole @default(SEEKER)

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  refreshTokens RefreshToken[]
  vacancies     Vacancy[]
  applications  Application[]
  wishlist      Wishlist[]
  notifications Notification[]
  calendarEvents CalendarEvent[]
  documents      Document[]
  companies      Company[]
  contacts       Contact[]
  applicationNotes ApplicationNote[]
  tags           Tag[]
  reminders      Reminder[]

  @@index([email])
  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

enum VacancyStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  REJECTED
  OFFER
  ACCEPTED
  WITHDRAWN
}

enum CalendarEventType {
  INTERVIEW
  MEETING
  DEADLINE
  FOLLOW_UP
  NOTE
  OTHER
}

enum DocumentType {
  RESUME
  COVER_LETTER
}

model Vacancy {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  title        String
  description  String
  requirements String?

  position  String?
  company   String?
  location  String?
  salaryMin Int?    @map("salary_min")
  salaryMax Int?    @map("salary_max")
  currency  String  @default("USD")

  status VacancyStatus @default(DRAFT)

  recruiterId String @db.Uuid
  recruiter   User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  applications Application[]
  wishlist     Wishlist[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")
  closedAt    DateTime? @map("closed_at")
  expiresAt   DateTime? @map("expires_at")
  archivedAt  DateTime? @map("archived_at")

  @@index([recruiterId])
  @@index([status])
  @@index([archivedAt])
  @@index([expiresAt])
  @@index([createdAt(sort: Desc)])
  @@map("vacancies")
}

model Application {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  status ApplicationStatus @default(APPLIED)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vacancyId String  @db.Uuid
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  interviewDate DateTime? @map("interview_date")
  interviewTime String?   @map("interview_time")
  interviewNotes String?  @map("interview_notes")

  calendarEvent CalendarEvent?
  documents     ApplicationDocument[]
  notes         ApplicationNote[]
  tags          ApplicationTag[]
  reminders     Reminder[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, vacancyId])
  @@index([userId])
  @@index([vacancyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("applications")
}

model Document {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type DocumentType
  originalFilename String @map("original_filename") @db.VarChar(255)
  publicId String @map("public_id")
  isCurrent Boolean @default(true) @map("is_current")

  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationDocument[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, type, isCurrent])
  @@map("documents")
}

model ApplicationDocument {
  applicationId String @db.Uuid
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentId String @db.Uuid
  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)
  type DocumentType

  @@id([applicationId, type])
  @@index([documentId])
  @@map("application_documents")
}

model Company {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(255)
  website String?
  location String?
  notes String? @db.Text
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([userId, name])
  @@index([userId])
  @@map("companies")
}

model Contact {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String @map("first_name")
  lastName String @map("last_name")
  email String?
  phone String?
  role String?
  notes String? @db.Text
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String? @db.Uuid
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@index([companyId])
  @@map("contacts")
}

model ApplicationNote {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content String @db.Text
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String @db.Uuid
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@index([applicationId])
  @@map("application_notes")
}

model Tag {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(50)
  color String @default("blue") @db.VarChar(32)
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationTag[]
  createdAt DateTime @default(now()) @map("created_at")
  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model ApplicationTag {
  applicationId String @db.Uuid
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tagId String @db.Uuid
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([applicationId, tagId])
  @@index([tagId])
  @@map("application_tags")
}

model Reminder {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title String @db.VarChar(255)
  dueAt DateTime @map("due_at")
  completedAt DateTime? @map("completed_at")
  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String? @db.Uuid
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([userId, dueAt])
  @@index([applicationId])
  @@map("reminders")
}

model Wishlist {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vacancyId String  @db.Uuid
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, vacancyId])
  @@index([userId])
  @@index([vacancyId])
  @@map("wishlist")
}

model Notification {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  type String
  title String
  message String
  metadata Json?
  isRead Boolean @default(false) @map("is_read")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicationId String? @db.Uuid
  vacancyId     String? @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model CalendarEvent {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  title       String @db.VarChar(255)
  description String? @db.Text
  eventType   CalendarEventType @default(INTERVIEW)
  color       String @default("blue")

  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicationId String?      @unique @db.Uuid
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  location    String?
  isCompleted Boolean @default(false) @map("is_completed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([applicationId])
  @@index([startTime(sort: Asc)])
  @@index([eventType])
  @@map("calendar_events")
}
